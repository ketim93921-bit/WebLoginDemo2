@model WebLoginDemo2.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>登入 - 智慧農業核心系統</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #10b981;
            --primary-dark: #047857;
            --bg-gradient: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            --glass: rgba(255, 255, 255, 0.9);
            --border: rgba(226, 232, 240, 0.8);
            --text-main: #0f172a;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-wrapper {
            width: 100%;
            max-width: 1000px;
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08);
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            overflow: hidden;
            min-height: 600px;
        }

        .form-side {
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 20px;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #34d399, #10b981);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
        }

        .welcome-text h1 {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .welcome-text p {
            color: var(--text-muted);
            font-size: 14px;
            margin-bottom: 32px;
        }

        .input-group-custom {
            margin-bottom: 20px;
            position: relative;
        }

            .input-group-custom label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                color: var(--text-main);
                margin-bottom: 6px;
            }

        .input-field {
            width: 100%;
            padding: 12px 16px 12px 42px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.2s;
            background: #f8fafc;
        }

            .input-field:focus {
                background: #fff;
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
                outline: none;
            }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 38px;
            color: #94a3b8;
            font-size: 16px;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: .2s;
            margin-top: 10px;
        }

            .btn-submit:hover {
                background: var(--primary-dark);
                transform: translateY(-1px);
            }

        .visual-side {
            background: linear-gradient(rgba(4, 120, 87, 0.85), rgba(6, 78, 59, 0.9)), url('https://images.unsplash.com/photo-1530836369250-ef72a3f5cda8?auto=format&fit=crop&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            color: white;
        }

        .visual-content {
            z-index: 2;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 20px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            margin-bottom: 24px;
            max-width: 320px;
        }

        .stat-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 12px;
            opacity: 0.8;
        }

        .stat-val {
            font-size: 18px;
            font-weight: 700;
        }

        .visual-title {
            font-size: 32px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 12px;
        }

        .visual-desc {
            opacity: 0.8;
            font-size: 14px;
            line-height: 1.6;
        }

        @@media (max-width: 768px) {
            .login-wrapper {
                grid-template-columns: 1fr;
                min-height: auto;
            }

            .visual-side {
                display: none;
            }

            .form-side {
                padding: 32px 24px;
            }
        }
    </style>
</head>

<body>
    <div class="login-wrapper">
        <div class="form-side">
            <div class="brand-logo">
                <div class="logo-icon">
                    <i class="bi bi-cpu-fill"></i>
                </div>
                <span>AgriTech Core</span>
            </div>

            <div class="welcome-text">
                <h1>歡迎回來</h1>
                <p>請輸入您的帳號密碼以存取監控儀表板</p>
            </div>

            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger py-2 small border-0 bg-danger-subtle text-danger mb-4"
                 role="alert"></div>

            <form asp-action="Login" asp-controller="Auth" method="post">
                @Html.AntiForgeryToken()

                <div class="input-group-custom">
                    <label asp-for="UserName">帳號</label>
                    <i class="bi bi-person field-icon"></i>
                    <input asp-for="UserName"
                           class="input-field"
                           placeholder="請輸入使用者帳號"
                           autocomplete="username" />
                    <span asp-validation-for="UserName"
                          class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="input-group-custom">
                    <label asp-for="Password">密碼</label>
                    <i class="bi bi-lock field-icon"></i>
                    <input asp-for="Password"
                           class="input-field"
                           placeholder="請輸入密碼"
                           autocomplete="current-password" />
                    <span asp-validation-for="Password"
                          class="text-danger small mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn-submit">
                    登入系統 <i class="bi bi-arrow-right ms-2"></i>
                </button>

                <div class="text-center mt-4">
                    <span class="text-muted small">僅限系統管理員登入</span>
                </div>
            </form>
        </div>

        <div class="visual-side">
            <div class="visual-content">
                <div class="glass-card">
                    <div class="stat-row">
                        <span class="stat-label">
                            <i class="bi bi-broadcast me-1"></i>系統狀態
                        </span>
                        <span class="badge bg-success bg-opacity-75">Online</span>
                    </div>

                    <div class="stat-row mt-2">
                        <span class="stat-label">即時監測點</span>
                        <span class="stat-val">12 Active</span>
                    </div>
                </div>

                <div class="visual-title">
                    智慧數據驅動<br>精準農業未來
                </div>

                <div class="visual-desc">
                    透過 IoT 感測技術與雲端分析，全天候監控溫室環境，讓作物生長在最佳狀態。
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>