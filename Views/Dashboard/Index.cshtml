@{
    Layout = null;
    ViewData["Title"] = "智慧農場監控";
    var userName = User?.Identity?.Name ?? "管理員";
}

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        :root {
            --bg-body: #f0f2f5;
            --surface: rgba(255, 255, 255, 0.9);
            --surface-glass: rgba(255, 255, 255, 0.65);
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --border: rgba(255, 255, 255, 0.8);
            --accent-temp: #ff6b6b;
            --accent-hum: #4dabf7;
            --accent-soil: #ae3ec9;
            --accent-ok: #20c997;
            --accent-warn: #ff8787;
            --shadow-card: 0 8px 32px 0 rgba(31, 38, 135, 0.07);
        }

        [data-theme="dark"] {
            --bg-body: #0f172a;
            --surface: rgba(30, 41, 59, 0.85);
            --surface-glass: rgba(15, 23, 42, 0.6);
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --border: rgba(255, 255, 255, 0.05);
            --shadow-card: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-body);
            background-image: radial-gradient(at 0% 0%, rgba(77, 171, 247, 0.1) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(174, 62, 201, 0.1) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text-primary);
            transition: background 0.3s ease;
            min-height: 100vh;
            padding-bottom: 50px;
        }

        .glass-nav {
            background: var(--surface-glass);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            margin-bottom: 30px;
        }

        .container-custom {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            height: 100%;
            min-height: 200px;
            box-shadow: var(--shadow-card);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px -10px rgba(0,0,0,0.15);
            }

        .card-bg-circle {
            position: absolute;
            top: -20px;
            right: -20px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            opacity: 0.1;
            filter: blur(20px);
        }

        .card-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .icon-circle {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        .value-display {
            font-family: 'JetBrains Mono', monospace;
            font-size: 42px;
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1;
            margin-bottom: 5px;
            position: relative;
            z-index: 2;
        }

        .unit-label {
            font-size: 15px;
            color: var(--text-secondary);
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .skeleton {
            background: linear-gradient(90deg, rgba(150,150,150,0.1) 25%, rgba(150,150,150,0.2) 50%, rgba(150,150,150,0.1) 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
            border-radius: 8px;
        }

        .skeleton-text {
            height: 40px;
            width: 80px;
            display: none;
        }

        @@keyframes loading {
            0% {
                background-position: 200% 0;
            }

            100% {
                background-position: -200% 0;
            }
        }

        .status-pill {
            padding: 4px 12px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .status-pill.ok {
                background: rgba(32, 201, 151, 0.1);
                color: var(--accent-ok);
            }

            .status-pill.warn {
                background: rgba(255, 135, 135, 0.1);
                color: var(--accent-warn);
            }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: currentColor;
        }

        .chart-container-glass {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 30px;
            box-shadow: var(--shadow-card);
            margin-top: 30px;
        }

        .btn-toggle {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-secondary);
            padding: 8px 16px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            transition: 0.2s;
        }

            .btn-toggle:hover,
            .btn-toggle.active {
                background: var(--text-primary);
                color: var(--bg-body);
            }

            .btn-toggle:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

        .grid-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }
    </style>
</head>
<body>

    <nav class="glass-nav">
        <div class="container-custom d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div class="icon-circle" style="background: var(--accent-ok); color: white;">
                    <i class="bi bi-flower1"></i>
                </div>
                <div>
                    <h5 class="m-0 fw-bold">智慧農場 <span style="font-weight:300">IoT</span></h5>
                    <small class="text-secondary" style="font-size:11px;">即時監控系統</small>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div id="connectionStatus" class="status-pill warn">
                    <div class="status-dot"></div>
                    <span id="connText">連線中...</span>
                </div>
                <div class="vr mx-2 text-secondary"></div>
                <button class="btn-toggle" onclick="toggleTheme()">
                    <i class="bi bi-moon"></i>
                </button>
            </div>
        </div>
    </nav>

    <div class="container-custom">

        <div class="mb-4 d-flex justify-content-between align-items-end flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">監控儀表板</h2>
                <p class="text-secondary m-0">歡迎回來，@userName。系統目前運作正常。</p>
            </div>
            <div class="d-flex gap-2">
                <a id="exportBtn" href="#" class="btn-toggle text-decoration-none">
                    <i class="bi bi-file-earmark-excel"></i> 匯出報表 (CSV)
                </a>
            </div>
        </div>

        <div class="grid-layout">

            <!-- 溫度 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-temp)">
                <div class="card-bg-circle" style="background: var(--accent-temp)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(255,107,107,0.1); color: var(--accent-temp)">
                        <i class="bi bi-thermometer-half"></i>
                    </div>
                    <div class="status-pill ok" id="temp_badge">
                        <div class="status-dot"></div> 正常
                    </div>
                </div>
                <div>
                    <div id="temp_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="temp_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">環境溫度 (°C)</div>
                </div>
            </div>

            <!-- 濕度 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-hum)">
                <div class="card-bg-circle" style="background: var(--accent-hum)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(77,171,247,0.1); color: var(--accent-hum)">
                        <i class="bi bi-droplet-fill"></i>
                    </div>
                    <div class="status-pill ok" id="hum_badge">
                        <div class="status-dot"></div> 正常
                    </div>
                </div>
                <div>
                    <div id="hum_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="hum_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">環境濕度 (%)</div>
                </div>
            </div>

            <!-- 土壤 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-soil)">
                <div class="card-bg-circle" style="background: var(--accent-soil)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(174,62,201,0.1); color: var(--accent-soil)">
                        <i class="bi bi-moisture"></i>
                    </div>
                    <div class="status-pill ok" id="soil_badge">
                        <div class="status-dot"></div> 檢測中
                    </div>
                </div>
                <div>
                    <div id="soil_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="soil_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">土壤狀態</div>
                </div>
            </div>

            <!-- Relay1 / 風扇 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-ok)">
                <div class="card-bg-circle" style="background: var(--accent-ok)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(32,201,151,0.1); color: var(--accent-ok)">
                        <i class="bi bi-fan"></i>
                    </div>
                    <div class="status-pill ok" id="relay1_badge">
                        <div class="status-dot"></div> 讀取中
                    </div>
                </div>
                <div>
                    <div id="relay1_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="relay1_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">Relay1 / 風扇</div>

                    <div class="d-flex gap-2 mt-3">
                        <button id="relay1OnBtn" class="btn-toggle flex-fill" onclick="controlRelay(1, true)">開啟</button>
                        <button id="relay1OffBtn" class="btn-toggle flex-fill" onclick="controlRelay(1, false)">關閉</button>
                    </div>
                </div>
            </div>

            <!-- Relay5 / 土壤控制 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-hum)">
                <div class="card-bg-circle" style="background: var(--accent-hum)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(77,171,247,0.1); color: var(--accent-hum)">
                        <i class="bi bi-droplet"></i>
                    </div>
                    <div class="status-pill ok" id="relay5_badge">
                        <div class="status-dot"></div> 讀取中
                    </div>
                </div>
                <div>
                    <div id="relay5_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="relay5_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">Relay5 / 土壤控制</div>

                    <div class="d-flex gap-2 mt-3">
                        <button id="relay5OnBtn" class="btn-toggle flex-fill" onclick="controlRelay(5, true)">開啟</button>
                        <button id="relay5OffBtn" class="btn-toggle flex-fill" onclick="controlRelay(5, false)">關閉</button>
                    </div>
                </div>
            </div>

            <!-- Relay6 / 人工定時 -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-soil)">
                <div class="card-bg-circle" style="background: var(--accent-soil)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(174,62,201,0.1); color: var(--accent-soil)">
                        <i class="bi bi-power"></i>
                    </div>
                    <div class="status-pill ok" id="relay6_badge">
                        <div class="status-dot"></div> 讀取中
                    </div>
                </div>
                <div>
                    <div id="relay6_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="relay6_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">Relay6 / 人工定時</div>

                    <div class="d-flex gap-2 mt-3">
                        <button id="relay6OnBtn" class="btn-toggle flex-fill" onclick="controlRelay(6, true)">開啟</button>
                        <button id="relay6OffBtn" class="btn-toggle flex-fill" onclick="controlRelay(6, false)">關閉</button>
                    </div>

                    <div class="mt-3">
                        <label class="unit-label mb-2 d-block">Relay6 定時控制</label>

                        <div class="d-flex gap-2">
                            <select id="relay6TimerUnit" class="btn-toggle flex-fill">
                                <option value="1">15 分鐘</option>
                                <option value="2">30 分鐘</option>
                                <option value="3">45 分鐘</option>
                                <option value="4">60 分鐘</option>
                                <option value="6">90 分鐘</option>
                                <option value="8">120 分鐘</option>
                            </select>

                            <button id="relay6TimerBtn"
                                    class="btn-toggle flex-fill"
                                    onclick="controlRelay6Timer()">
                                啟動定時
                            </button>
                        </div>

                        <button id="relay6CancelTimerBtn"
                                class="btn-toggle w-100 mt-2"
                                onclick="cancelRelay6Timer()">
                            取消定時並關閉
                        </button>
                    </div>
                </div>
            </div>

            <!-- Stepper -->
            <div class="stat-card" style="border-bottom: 4px solid var(--accent-temp)">
                <div class="card-bg-circle" style="background: var(--accent-temp)"></div>
                <div class="card-header-custom">
                    <div class="icon-circle" style="background: rgba(255,107,107,0.1); color: var(--accent-temp)">
                        <i class="bi bi-gear-wide-connected"></i>
                    </div>
                    <div class="status-pill ok" id="stepper_badge">
                        <div class="status-dot"></div> 讀取中
                    </div>
                </div>
                <div>
                    <div id="stepper_skel" class="skeleton skeleton-text" style="display:block;"></div>
                    <div id="stepper_value" class="value-display" style="display:none;">--</div>
                    <div class="unit-label">步進馬達</div>

                    <div class="d-flex gap-2 mt-3">
                        <button id="stepperOnBtn" class="btn-toggle flex-fill" onclick="controlStepper(true)">啟動</button>
                        <button id="stepperOffBtn" class="btn-toggle flex-fill" onclick="controlStepper(false)">關閉</button>
                    </div>
                </div>
            </div>

        </div>

        <!-- 趨勢分析 -->
        <div class="chart-container-glass">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <h4 class="fw-bold m-0">
                    <i class="bi bi-activity text-primary me-2"></i>趨勢分析
                </h4>

                <div class="d-flex gap-2">
                    <div class="btn-group" role="group">
                        <button class="btn-toggle active" onclick="changeMetric('temp', this)">溫度</button>
                        <button class="btn-toggle" onclick="changeMetric('humidity', this)">濕度</button>
                        <button class="btn-toggle" onclick="changeMetric('soil', this)">土壤</button>
                    </div>
                    <div class="vr text-secondary"></div>
                    <div class="btn-group" role="group">
                        <button class="btn-toggle active" onclick="changeDuration(10, this)">10分鐘</button>
                        <button class="btn-toggle" onclick="changeDuration(30, this)">30分鐘</button>
                        <button class="btn-toggle" onclick="changeDuration(60, this)">1小時</button>
                    </div>
                </div>
            </div>

            <div style="height: 350px; width: 100%;">
                <canvas id="historyChart"></canvas>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.14/signalr.min.js"></script>

    <script>
        let chartInstance = null;
        let currentMetric = 'temp';
        let currentDuration = 10;
        let hubConnection = null;
        let historyRefreshTimer = null;

        const COLORS = {
            temp: '#ff6b6b',
            humidity: '#4dabf7',
            soil: '#ae3ec9'
        };

        function getVal(data, key) {
            if (!data) return null;

            const candidates = [
                key,
                key.charAt(0).toUpperCase() + key.slice(1),
                key.toUpperCase()
            ];

            for (let k of candidates) {
                if (k && data[k] !== undefined) return data[k];
            }

            return null;
        }

        function isOn(value) {
            return value === true ||
                value === 1 ||
                value === "1" ||
                String(value).toUpperCase() === "ON" ||
                String(value).toUpperCase() === "TRUE";
        }

        function updateDashboard(data) {
            console.log("收到數據 (Raw):", data);

            const temp = getVal(data, 'temp');
            const humidity = getVal(data, 'humidity');
            const soil = getVal(data, 'soil');
            const soilState = getVal(data, 'soilState');

            updateSingleCard('temp', temp);
            updateSingleCard('hum', humidity);

            updateTempBadge(temp);
            updateHumBadge(humidity);
            updateSoilUI(soil, soilState);

            updateRelayUI(1, getVal(data, 'relay1'));
            updateRelayUI(5, getVal(data, 'relay5'));
            updateRelayUI(6, getVal(data, 'relay6'));
            updateStepperUI(getVal(data, 'stepper'));
        }

        function updateSingleCard(idPrefix, val) {
            const el = document.getElementById(idPrefix + '_value');
            const skel = document.getElementById(idPrefix + '_skel');

            if (!el || !skel) return;

            if (val !== null && val !== undefined) {
                skel.style.display = 'none';
                el.style.display = 'block';
                el.innerText = Number(val).toFixed(1);
            }
        }

        function updateTempBadge(t) {
            const badge = document.getElementById('temp_badge');
            if (!badge || t === null || t === undefined) return;

            const warn = Number(t) > 35 || Number(t) < 10;

            badge.className = warn ? 'status-pill warn' : 'status-pill ok';
            badge.innerHTML = warn
                ? '<div class="status-dot"></div>異常'
                : '<div class="status-dot"></div>正常';
        }

        function updateHumBadge(h) {
            const badge = document.getElementById('hum_badge');
            if (!badge || h === null || h === undefined) return;

            const warn = Number(h) < 40;

            badge.className = warn ? 'status-pill warn' : 'status-pill ok';
            badge.innerHTML = warn
                ? '<div class="status-dot"></div>偏低'
                : '<div class="status-dot"></div>正常';
        }

        function translateSoilState(state) {
            const s = String(state || '').toUpperCase();

            if (s === 'DRY') return '乾燥';
            if (s === 'MOIST') return '適中';
            if (s === 'WET') return '濕潤';

            return state || '未知';
        }

        function updateSoilUI(soil, soilState) {
            const soilEl = document.getElementById('soil_value');
            const soilSkel = document.getElementById('soil_skel');
            const soilBadge = document.getElementById('soil_badge');

            if (!soilEl || !soilSkel || !soilBadge) return;

            if (soil !== null && soil !== undefined) {
                soilSkel.style.display = 'none';
                soilEl.style.display = 'block';

                const stateText = translateSoilState(soilState);
                const isDry = String(soilState || '').toUpperCase() === 'DRY';

                soilEl.innerText = `${Number(soil).toFixed(0)} / ${stateText}`;
                soilEl.style.color = isDry ? "var(--accent-warn)" : "var(--accent-ok)";

                soilBadge.className = isDry ? "status-pill warn" : "status-pill ok";
                soilBadge.innerHTML = isDry
                    ? '<div class="status-dot"></div>需澆水'
                    : '<div class="status-dot"></div>良好';
            }
        }

        function updateRelayUI(relayNumber, value) {
            const relayEl = document.getElementById(`relay${relayNumber}_value`);
            const relaySkel = document.getElementById(`relay${relayNumber}_skel`);
            const relayBadge = document.getElementById(`relay${relayNumber}_badge`);
            const onBtn = document.getElementById(`relay${relayNumber}OnBtn`);
            const offBtn = document.getElementById(`relay${relayNumber}OffBtn`);

            if (!relayEl || !relaySkel || !relayBadge) return;

            if (value !== null && value !== undefined) {
                relaySkel.style.display = 'none';
                relayEl.style.display = 'block';

                const active = isOn(value);

                relayEl.innerText = active ? "開啟" : "關閉";
                relayEl.style.color = active ? "var(--accent-ok)" : "var(--accent-warn)";

                relayBadge.className = active ? "status-pill ok" : "status-pill warn";
                relayBadge.innerHTML = active
                    ? '<div class="status-dot"></div>ON'
                    : '<div class="status-dot"></div>OFF';

                if (onBtn) onBtn.classList.toggle('active', active);
                if (offBtn) offBtn.classList.toggle('active', !active);
            }
        }

        function updateStepperUI(value) {
            const el = document.getElementById('stepper_value');
            const skel = document.getElementById('stepper_skel');
            const badge = document.getElementById('stepper_badge');
            const onBtn = document.getElementById('stepperOnBtn');
            const offBtn = document.getElementById('stepperOffBtn');

            if (!el || !skel || !badge) return;

            if (value !== null && value !== undefined) {
                skel.style.display = 'none';
                el.style.display = 'block';

                const active = isOn(value);

                el.innerText = active ? "啟動" : "關閉";
                el.style.color = active ? "var(--accent-ok)" : "var(--accent-warn)";

                badge.className = active ? "status-pill ok" : "status-pill warn";
                badge.innerHTML = active
                    ? '<div class="status-dot"></div>運轉中'
                    : '<div class="status-dot"></div>已停止';

                if (onBtn) onBtn.classList.toggle('active', active);
                if (offBtn) offBtn.classList.toggle('active', !active);
            }
        }

        async function controlRelay(relayNumber, on) {
            const onBtn = document.getElementById(`relay${relayNumber}OnBtn`);
            const offBtn = document.getElementById(`relay${relayNumber}OffBtn`);

            if (onBtn) onBtn.disabled = true;
            if (offBtn) offBtn.disabled = true;

            try {
                const url = on
                    ? `/api/control/relay/${relayNumber}/on`
                    : `/api/control/relay/${relayNumber}/off`;

                const res = await fetch(url, { method: 'POST' });

                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }

                updateRelayUI(relayNumber, on);
            } catch (err) {
                console.error(`❌ Relay${relayNumber} 控制失敗:`, err);
                alert(`Relay${relayNumber} 控制失敗，請檢查後端與 MQTT 連線。`);
            } finally {
                if (onBtn) onBtn.disabled = false;
                if (offBtn) offBtn.disabled = false;
            }
        }

        async function controlRelay6Timer() {
            const select = document.getElementById('relay6TimerUnit');
            const timerBtn = document.getElementById('relay6TimerBtn');
            const cancelBtn = document.getElementById('relay6CancelTimerBtn');

            if (!select) return;

            const unitCount = Number(select.value);

            if (timerBtn) timerBtn.disabled = true;
            if (cancelBtn) cancelBtn.disabled = true;

            try {
                const res = await fetch(`/api/control/relay6/timer/${unitCount}`, {
                    method: 'POST'
                });

                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }

                updateRelayUI(6, true);

                alert(`Relay6 已啟動定時 ${unitCount * 15} 分鐘`);
            } catch (err) {
                console.error("❌ Relay6 定時控制失敗:", err);
                alert("Relay6 定時控制失敗，請檢查後端與 MQTT 連線。");
            } finally {
                if (timerBtn) timerBtn.disabled = false;
                if (cancelBtn) cancelBtn.disabled = false;
            }
        }

        async function cancelRelay6Timer() {
            const timerBtn = document.getElementById('relay6TimerBtn');
            const cancelBtn = document.getElementById('relay6CancelTimerBtn');

            if (timerBtn) timerBtn.disabled = true;
            if (cancelBtn) cancelBtn.disabled = true;

            try {
                const res = await fetch('/api/control/relay6/timer/0', {
                    method: 'POST'
                });

                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }

                updateRelayUI(6, false);

                alert("Relay6 定時已取消並關閉");
            } catch (err) {
                console.error("❌ Relay6 取消定時失敗:", err);
                alert("Relay6 取消定時失敗，請檢查後端與 MQTT 連線。");
            } finally {
                if (timerBtn) timerBtn.disabled = false;
                if (cancelBtn) cancelBtn.disabled = false;
            }
        }

        async function controlStepper(on) {
            const onBtn = document.getElementById('stepperOnBtn');
            const offBtn = document.getElementById('stepperOffBtn');

            if (onBtn) onBtn.disabled = true;
            if (offBtn) offBtn.disabled = true;

            try {
                const url = on
                    ? '/api/control/stepper/on'
                    : '/api/control/stepper/off';

                const res = await fetch(url, { method: 'POST' });

                if (!res.ok) {
                    const text = await res.text();
                    throw new Error(text);
                }

                updateStepperUI(on);
            } catch (err) {
                console.error("❌ 步進馬達控制失敗:", err);
                alert("步進馬達控制失敗，請檢查後端與 MQTT 連線。");
            } finally {
                if (onBtn) onBtn.disabled = false;
                if (offBtn) offBtn.disabled = false;
            }
        }

        async function startSignalR() {
            const statusBadge = document.getElementById('connectionStatus');
            const statusText = document.getElementById('connText');

            try {
                hubConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/sensorHub")
                    .withAutomaticReconnect()
                    .build();

                hubConnection.on("ReceiveSensorData", (data) => {
                    updateDashboard(data);
                });

                hubConnection.onreconnecting(() => {
                    if (statusBadge) statusBadge.className = "status-pill warn";
                    if (statusText) statusText.innerText = "重新連線中...";
                });

                hubConnection.onreconnected(() => {
                    if (statusBadge) statusBadge.className = "status-pill ok";
                    if (statusText) statusText.innerText = "已連線";
                });

                hubConnection.onclose(() => {
                    if (statusBadge) statusBadge.className = "status-pill warn";
                    if (statusText) statusText.innerText = "已斷線";
                });

                await hubConnection.start();
                console.log("✅ SignalR 已連線");

                if (statusBadge) statusBadge.className = "status-pill ok";
                if (statusText) statusText.innerText = "已連線";
            } catch (err) {
                console.error("❌ SignalR 連線錯誤:", err);

                if (statusBadge) statusBadge.className = "status-pill warn";
                if (statusText) statusText.innerText = "SignalR 失敗";

                setTimeout(startSignalR, 5000);
            }
        }

        async function loadLatest() {
            try {
                console.log("開始載入 Latest...");
                const res = await fetch('/Data/Latest');

                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const data = await res.json();
                console.log("Latest 成功:", data);
                updateDashboard(data);
            } catch (e) {
                console.error("最新資料載入失敗:", e);

                const statusBadge = document.getElementById('connectionStatus');
                const statusText = document.getElementById('connText');

                if (statusBadge) statusBadge.className = "status-pill warn";
                if (statusText) statusText.innerText = "Latest 失敗";
            }
        }

        async function loadHistory() {
            const exportBtn = document.getElementById('exportBtn');

            if (exportBtn) {
                exportBtn.href = `/Data/Export?minutes=${currentDuration}`;
            }

            const canvas = document.getElementById('historyChart');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            if (chartInstance) chartInstance.destroy();

            try {
                console.log("開始載入 History...");
                const res = await fetch(`/Data/History?minutes=${currentDuration}`);

                if (!res.ok) throw new Error(`HTTP ${res.status}`);

                const data = await res.json();
                console.log("History 成功:", data);

                const values = data.map(d => Number(getVal(d, currentMetric)) || 0);
                const rawTimes = data.map(d => new Date(d.time || d.Time || d.CreatedAt));

                const labels = [];
                let lastBucketKey = "";

                for (const dt of rawTimes) {
                    const hh = String(dt.getHours()).padStart(2, '0');
                    const bucketMinute = Math.floor(dt.getMinutes() / 5) * 5;
                    const mm = String(bucketMinute).padStart(2, '0');

                    const bucketKey = `${hh}:${mm}`;

                    if (bucketKey !== lastBucketKey) {
                        labels.push(bucketKey);
                        lastBucketKey = bucketKey;
                    } else {
                        labels.push('');
                    }
                }

                let gradient = ctx.createLinearGradient(0, 0, 0, 400);
                gradient.addColorStop(0, COLORS[currentMetric] + '50');
                gradient.addColorStop(1, COLORS[currentMetric] + '00');

                chartInstance = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: currentMetric.toUpperCase(),
                            data: values,
                            borderColor: COLORS[currentMetric],
                            backgroundColor: gradient,
                            borderWidth: 3,
                            pointRadius: 0,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    title: function (context) {
                                        const idx = context[0].dataIndex;
                                        return rawTimes[idx].toLocaleTimeString('zh-TW', {
                                            hour12: true,
                                            hour: '2-digit',
                                            minute: '2-digit',
                                            second: '2-digit'
                                        });
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: {
                                    color: '#888',
                                    autoSkip: false,
                                    maxRotation: 0,
                                    minRotation: 0
                                }
                            },
                            y: {
                                border: { display: false },
                                grid: { color: 'rgba(200,200,200,0.1)' }
                            }
                        },
                        interaction: {
                            mode: 'index',
                            intersect: false
                        }
                    }
                });
            } catch (e) {
                console.error("歷史數據載入失敗:", e);
            }
        }

        function startHistoryAutoRefresh() {
            if (historyRefreshTimer) {
                clearInterval(historyRefreshTimer);
            }

            historyRefreshTimer = setInterval(() => {
                console.log("⏰ 圖表每 10 分鐘自動更新一次");
                loadHistory();
            }, 10 * 60 * 1000);
        }

        function changeMetric(m, btn) {
            currentMetric = m;

            document.querySelectorAll('.btn-toggle').forEach(b => {
                if (b.parentElement === btn.parentElement) {
                    b.classList.remove('active');
                }
            });

            btn.classList.add('active');
            loadHistory();
        }

        function changeDuration(d, btn) {
            currentDuration = d;

            document.querySelectorAll('.btn-toggle').forEach(b => {
                if (b.parentElement === btn.parentElement) {
                    b.classList.remove('active');
                }
            });

            btn.classList.add('active');
            loadHistory();
        }

        function toggleTheme() {
            const body = document.body;
            body.setAttribute(
                'data-theme',
                body.getAttribute('data-theme') === 'dark' ? '' : 'dark'
            );

            loadHistory();
        }

        document.addEventListener('DOMContentLoaded', async () => {
            console.log("✅ DOMContentLoaded 已觸發");

            await loadLatest();
            await loadHistory();

            startSignalR();
            startHistoryAutoRefresh();
        });
    </script>
</body>
</html>